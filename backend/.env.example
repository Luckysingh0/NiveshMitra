# ---- Server ----
PORT=5000

# ---- MongoDB ----
# Local: mongodb://127.0.0.1:27017/niveshmitra
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/niveshmitra
MONGODB_URI=mongodb://127.0.0.1:27017/niveshmitra

# ---- LLM provider: "gemini" (recommended free) | "openrouter" ----
LLM_PROVIDER=gemini

# ---- Google Gemini (free key: https://aistudio.google.com/apikey) ----
# Uses the NATIVE REST API (X-goog-api-key header) — works with both
# "AQ." AI-Studio keys and "AIza" keys.
GEMINI_API_KEY=
# Pick a model your project has quota for (gemini-2.5-flash is a solid free pick).
GEMINI_MODEL=gemini-2.5-flash
# Tried in order if the primary model is overloaded (503).
GEMINI_FALLBACK_MODELS=gemini-flash-lite-latest,gemini-3-flash-preview

# ---- OpenRouter (https://openrouter.ai/keys) ----
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Free models (pick one). Some free models support JSON mode, some don't —
# our parser handles both. Good free options:
#   meta-llama/llama-3.3-70b-instruct:free
#   deepseek/deepseek-chat-v3-0324:free
#   google/gemini-2.0-flash-exp:free
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional attribution headers for OpenRouter rankings
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_SITE_NAME=NiveshMitra

# Set to "true" to force canned responses without calling the LLM (demo fallback).
# If OPENROUTER_API_KEY is empty, mock mode turns on automatically.
MOCK_LLM=false
